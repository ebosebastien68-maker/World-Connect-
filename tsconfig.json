{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {

    // ─── Target & Lib ──────────────────────────────────────────────
    "target": "ES2022",
    "lib": ["ES2022", "dom", "dom.iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",

    // ─── JSX ───────────────────────────────────────────────────────
    "jsx": "preserve",
    "jsxImportSource": "react",

    // ─── Résolution & Chemins ──────────────────────────────────────
    "baseUrl": ".",
    "paths": {
      "@/*":           ["./src/*"],
      "@/components/*": ["./src/components/*"],
      "@/lib/*":       ["./src/lib/*"],
      "@/hooks/*":     ["./src/hooks/*"],
      "@/types/*":     ["./src/types/*"],
      "@/styles/*":    ["./src/styles/*"],
      "@/store/*":     ["./src/store/*"],
      "@/utils/*":     ["./src/utils/*"],
      "@/config/*":    ["./src/config/*"],
      "@/server/*":    ["./src/server/*"]
    },
    "resolveJsonModule": true,
    "allowImportingTsExtensions": false,

    // ─── Qualité du code ───────────────────────────────────────────
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitReturns": true,
    "noImplicitOverride": true,
    "exactOptionalPropertyTypes": false,

    // ─── Interopérabilité ──────────────────────────────────────────
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,

    // ─── Performance ───────────────────────────────────────────────
    "incremental": true,
    "tsBuildInfoFile": ".next/cache/tsconfig.tsbuildinfo",
    "skipLibCheck": true,

    // ─── Output ────────────────────────────────────────────────────
    "noEmit": true,
    "isolatedModules": true,
    "allowJs": false,

    // ─── Plugins Next.js ───────────────────────────────────────────
    "plugins": [{ "name": "next" }]
  },

  "include": [
    "next-env.d.ts",
    "next.config.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.d.ts"
  ],

  "exclude": [
    "node_modules",
    ".next",
    "out",
    "dist",
    "coverage",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.spec.ts",
    "**/*.spec.tsx"
  ]
}
